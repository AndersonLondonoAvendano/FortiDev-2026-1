# Database
DATABASE_URL="postgresql://estudiante:estudiante123@127.0.0.1:5432/fortidev_db"

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET=fortidev-super-secret-jwt-key-change-this-in-production-minimum-64-chars-required-x
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=fortidev-refresh-secret-different-from-jwt-change-in-production-minimum-64-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# GitHub API (optional)
GITHUB_TOKEN=

# Semgrep scan temp dir (use a Windows-compatible path)
SCAN_TEMP_DIR=C:/tmp/fortidev-scans
