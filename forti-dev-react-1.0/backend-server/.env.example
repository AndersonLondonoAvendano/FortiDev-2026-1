# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fortidev"

# JWT
JWT_SECRET=           # minimum 64 random characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET= # different from JWT_SECRET, minimum 64 random characters
REFRESH_TOKEN_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# GitHub API (optional - increases rate limit from 60 to 5000 req/h)
GITHUB_TOKEN=

# Semgrep
SCAN_TEMP_DIR=/tmp/fortidev-scans
